{
  "$schema": "https://unpkg.com/@changesets/config@3/schema.json",
  "changelog": ["@changesets/changelog-github", { "repo": "vercel/flags" }],
  "commit": false,
  "fixed": [],
  "linked": [],
  "access": "public",
  "baseBranch": "main",
  "updateInternalDependencies": "patch",
  "ignore": [
    "playground",
    "shirt-shop",
    "svelte-example",
    "next-15",
    "next-16",
    "sveltekit-e2e",
    "snippets",
    "docs"
  ],
  "snapshot": {
    "useCalculatedVersion": true
  }
}
